ARG IMAGE

FROM $IMAGE AS altbase

ARG IMAGE
ARG IMAGE_TYPE="nightly"
ARG YEAR
ARG MONTH
ARG DAY
ARG ARCH

ENV IMAGE_NAME="core"
ENV IMAGE=$IMAGE
ENV IMAGE_TYPE=$IMAGE_TYPE
ENV YEAR=$YEAR
ENV MONTH=$MONTH
ENV DAY=$DAY
ENV ARCH=$ARCH
ENV BUILD_TYPE="default"

RUN --mount=type=bind,ro,source=./src/image.yml,target=/etc/apm/image.yml \
    --mount=type=bind,ro,source=./src/resources,target=/etc/apm/resources \
    apm system image build

# Lint image
RUN echo -e "\033[1;33m$(bootc container lint)\033[0m"

WORKDIR /

CMD ["/sbin/init"]
